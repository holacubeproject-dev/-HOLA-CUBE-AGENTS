{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "nixpacksPlan": {
            "providers": [
                "node"
            ],
            "variables": {
                "NIXPACKS_NODE_VERSION": "20"
            },
            "aptPkgs": [
                "wget",
                "gnupg",
                "ca-certificates",
                "libgconf-2-4",
                "libasound2",
                "libatk1.0-0",
                "libc6",
                "libcairo2",
                "libcups2",
                "libdbus-1-3",
                "libexpat1",
                "libfontconfig1",
                "libgcc1",
                "libgdk-pixbuf2.0-0",
                "libglib2.0-0",
                "libgtk-3-0",
                "libnspr4",
                "libpango-1.0-0",
                "libpangocairo-1.0-0",
                "libstdc++6",
                "libx11-6",
                "libx11-xcb1",
                "libxcb1",
                "libxcomposite1",
                "libxcursor1",
                "libxdamage1",
                "libxext6",
                "libxfixes3",
                "libxi6",
                "libxrandr2",
                "libxrender1",
                "libxss1",
                "libxtst6",
                "fonts-liberation",
                "libappindicator1",
                "libnss3",
                "lsb-release",
                "xdg-utils",
                "libgbm-dev"
            ]
        }
    },
    "deploy": {
        "startCommand": "cd backend && npm install && npm start",
        "restartPolicyType": "ON_FAILURE"
    }
}